{
  "name": "neem-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "hardhat:node": "npx hardhat node",
    "hardhat:compile": "npx hardhat compile",
    "hardhat:console": "npx hardhat console --network localhost",
    "deploy:nexus-v2": "npx hardhat ignition deploy ignition/modules/NexusV2.cjs --network localhost",
    "deploy:capital-v2": "npx hardhat ignition deploy ignition/modules/CapitalV2.cjs --network localhost",
    "deploy:verify-v2": "npx hardhat ignition deploy ignition/modules/VerifyV2.cjs --network localhost",
    "deploy:staking": "npx hardhat ignition deploy ignition/modules/NeemOSStaking.cjs --network localhost",
    "deploy:v2": "npm run deploy:nexus-v2 && npm run deploy:capital-v2 && npm run deploy:verify-v2 && npm run deploy:staking",
    "test": "npx hardhat test",
    "clean": "npx hardhat clean"
  },
  "dependencies": {
    "@chainlink/contracts": "^1.5.0",
    "@openzeppelin/contracts": "^5.6.1",
    "@openzeppelin/contracts-upgradeable": "^5.6.1",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@tanstack/react-query": "^5.91.0",
    "circomlibjs": "^0.1.7",
    "framer-motion": "^12.36.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "snarkjs": "^0.7.6",
    "viem": "^2.47.5",
    "wagmi": "^2.19.5"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@openzeppelin/hardhat-upgrades": "^3.9.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "hardhat": "^2.28.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "type": "module"
}
